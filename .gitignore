# ==========================================
# 1. FILE DỮ LIỆU
# ==========================================
# Bỏ qua toàn bộ dữ liệu thô (Bắt buộc để không đẩy file CSV nặng lên GitHub)
dataset/
*.csv

# Bỏ qua các file submission tạm thời, chỉ giữ lại file nộp cuối cùng
# submissions/*
# !submissions/submission.csv


# ==========================================
# 2. PYTHON & MÔI TRƯỜNG
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.env
.venv
env/
venv/
ENV/

# Jupyter Notebook
.ipynb_checkpoints

# Unit test / coverage reports
htmlcov/
.coverage
.pytest_cache/


# ==========================================
# 3. LATEX
# ==========================================
# Bỏ qua các file rác sinh ra trong quá trình biên dịch báo cáo NeurIPS
*.aux
*.bbl
*.blg
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc


# ==========================================
# 4. TRÌNH BIÊN TẬP CODE (IDE) & HỆ ĐIỀU HÀNH
# ==========================================
# VS Code
.vscode/

# PyCharm / JetBrains
.idea/

# Cursor / AI Editors
.cursorignore
.cursorindexingignore

# MacOS (File hệ thống ẩn)
.DS_Store
